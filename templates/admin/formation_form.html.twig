{% extends "admin/base.html.twig" %}
{% block body %}
    <div class="container mt-3">
        <h2 class="text-info">
            {% if formation.id %}
                Modifier une formation
            {% else %}
                Ajouter une formation
            {% endif %}
        </h2>
        <form method="POST">
            <input type="hidden" name="_token" value="{{ csrf_token('formation_form') }}">
            <div class="mb-3">
                <label for="title" class="form-label">Titre *</label>
                <input type="text" class="form-control" id="title" name="title" 
                       value="{{ formation.title }}" required>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea class="form-control" id="description" name="description" rows="3">{{ formation.description }}</textarea>
            </div>
            <div class="mb-3">
                <label for="videoId" class="form-label">Video ID (YouTube) *</label>
                <input type="text" class="form-control" id="videoId" name="videoId" 
                       value="{{ formation.videoId }}" required>
            </div>
            <div class="mb-3">
                <label for="publishedAt" class="form-label">Date de parution *</label>
                <input type="date" class="form-control" id="publishedAt" name="publishedAt" 
                       max="{{ "now"|date("Y-m-d") }}"
                       value="{{ formation.publishedAt ? formation.publishedAt|date('Y-m-d') : '' }}" required>
            </div>
            <div class="mb-3">
                <label for="playlist" class="form-label">Playlist *</label>
                <select class="form-select" id="playlist" name="playlist" required>
                    <option value="">-- Choisir une playlist --</option>
                    {% for playlist in playlists %}
                        <option value="{{ playlist.id }}"
                            {% if formation.playlist and formation.playlist.id == playlist.id %}selected{% endif %}>
                            {{ playlist.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Catégories</label>
                {% for categorie in categories %}
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" 
                               name="categories[]" value="{{ categorie.id }}"
                               id="cat{{ categorie.id }}"
                               {% if formation.categories is defined and categorie in formation.categories %}checked{% endif %}>
                        <label class="form-check-label" for="cat{{ categorie.id }}">
                            {{ categorie.name }}
                        </label>
                    </div>
                {% endfor %}
            </div>
            <button type="submit" class="btn btn-success">Enregistrer</button>
            <a href="{{ path('admin.formations') }}" class="btn btn-secondary">Annuler</a>
        </form>
    </div>
{% endblock %}