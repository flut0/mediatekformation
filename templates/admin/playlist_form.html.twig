{% extends "admin/base.html.twig" %}
{% block body %}
    <div class="container mt-3">
        <h2 class="text-info">
            {% if playlist.id %}
                Modifier une playlist
            {% else %}
                Ajouter une playlist
            {% endif %}
        </h2>
        <form method="POST">
            <input type="hidden" name="_token" value="{{ csrf_token('playlist_form') }}">
            <div class="mb-3">
                <label for="name" class="form-label">Nom *</label>
                <input type="text" class="form-control" id="name" name="name" 
                       value="{{ playlist.name }}" required>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea class="form-control" id="description" name="description" rows="3">{{ playlist.description }}</textarea>
            </div>
            {% if formations is defined and formations|length > 0 %}
                <div class="mb-3">
                    <label class="form-label">Formations de la playlist</label>
                    <ul class="list-group">
                        {% for formation in formations %}
                            <li class="list-group-item">{{ formation.title }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
            <button type="submit" class="btn btn-success">Enregistrer</button>
            <a href="{{ path('admin.playlists') }}" class="btn btn-secondary">Annuler</a>
        </form>
    </div>
{% endblock %}